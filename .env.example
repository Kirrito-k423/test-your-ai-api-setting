# AICodeMirror OpenAI-compatible settings
# Fill base URL from your dashboard "openai-sdk-docs" page.
# Example shape: https://your-endpoint.example.com/v1
AICM_BASE_URL=
AICM_API_KEY=
# Example from your docs: gpt-5.3-codex
AICM_MODEL=gpt-5.3-codex

# MiniMax OpenAI-compatible settings
# Token Plan in China mainland usually uses https://api.minimaxi.com
# If your key is issued for another region, switch to the corresponding base URL.
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_API_KEY=
